# ── Server ──────────────────────────────────────────
PORT=3050
HOST=127.0.0.1

# ── Database ────────────────────────────────────────
# Relative paths resolved from api/ directory
DATABASE_PATH=../db/tasks.db

# ── Auth ────────────────────────────────────────────
SESSION_EXPIRY_DAYS=7

# ── Admin Bootstrap ─────────────────────────────────
# Used by db/migrate.js to create the first admin user
ADMIN_EMAIL=joey@hollandexteriors.com
ADMIN_PASSWORD=          # leave blank to auto-generate
ADMIN_API_KEY=acc-live-20260129-4f2968fe5374c0d2

# Legacy fallback — if set, this key always authenticates as admin user #1
# Remove after confirming migration worked
LEGACY_API_KEY=acc-live-20260129-4f2968fe5374c0d2

# ── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_AGENCY=price_xxx

# ── CORS ────────────────────────────────────────────
CORS_ORIGINS=https://seo.hollandexteriors.com,http://localhost:3000

# ── App URL (for Stripe redirects) ──────────────────
APP_URL=https://seo.hollandexteriors.com/app
